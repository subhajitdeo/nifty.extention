{
  "manifest_version": 3,
  "name": "Nifty OI Levels",
  "version": "2.0",
  "description": "Draws Nifty OI levels on NSE chart",
  "permissions": [],
  "host_permissions": [
    "https://kdneyzemvqzhwzztflvq.supabase.co/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://charting.nseindia.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nifty OI Tools"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://charting.nseindia.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

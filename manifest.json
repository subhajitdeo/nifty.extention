{
  "manifest_version": 3,
  "name": "Nifty OI - Inject Test",
  "version": "2.0",
  "description": "Test inject.js approach",
  "permissions": [],
  "host_permissions": [
    "https://charting.nseindia.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://charting.nseindia.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://charting.nseindia.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

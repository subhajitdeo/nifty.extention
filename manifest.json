{
  "manifest_version": 3,
  "name": "Nifty OI Levels - Test",
  "version": "2.0",
  "description": "Minimal test version",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://charting.nseindia.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Test"
  },
  "content_scripts": [
    {
      "matches": ["https://charting.nseindia.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
